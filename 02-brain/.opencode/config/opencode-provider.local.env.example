# OpenCode provider example environment.
# Do not commit real secrets. Copy this to opencode-provider.local.env when
# OpenCode itself needs explicit model-provider env.
#
# Browser Use now starts through 01-runtime/tools/browser-use-local.cmd and loads
# browser-use.local.env in its own process, so this file is for OpenCode/Engineer
# only. Use OPENCODE_API_KEY for OpenCode Go when you do not rely on `opencode
# auth login` / `/connect`.
#
# Leave a key blank to clear a stale value inherited from the shell.

OPENCODE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=
