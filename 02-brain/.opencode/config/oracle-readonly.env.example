# Oracle Read-Only Example Connection
# This file is the shareable template for the real OpenCode MCP server `oracle_readonly`.
# Copy the structure into oracle-readonly.local.env and fill with real values locally.

ORACLE_PROFILE_NAME=dev-energy-readonly
ORACLE_CONNECTION_MODE=service_name
ORACLE_HOST=dbhost.example.internal
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=PGNDEV
ORACLE_SID=
ORACLE_TNS_ALIAS=
ORACLE_PROTOCOL=tcp
ORACLE_USERNAME=AI_QA_RO
ORACLE_PASSWORD=<fill-locally>
ORACLE_SCHEMA_ALLOWLIST=BILLING,TXMAP,MONITORING
ORACLE_ROLE=readonly_validation
ORACLE_RUNNER_MODE=auto
ORACLE_FORCE_JDBC=false
ORACLE_JDBC_JAR=
ORACLE_JDBC_URL=
ORACLE_USE_WALLET=false
ORACLE_WALLET_PATH=02-brain/.opencode/config/oracle-wallet
ORACLE_WALLET_PASSWORD=
ORACLE_REQUIRE_VPN=true
ORACLE_SOURCE_IP_NOTES=<vpn or source ip restriction>
ORACLE_CONNECTION_NOTES=<optional notes>

