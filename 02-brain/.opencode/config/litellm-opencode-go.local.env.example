# LiteLLM local proxy environment for OpenCode Go.
# Do not commit real secrets. Copy this to litellm-opencode-go.local.env.
#
# Browser Use should call the local LiteLLM proxy with LITELLM_MASTER_KEY.
# LiteLLM then calls OpenCode Go glm-5 with OPENCODE_GO_API_KEY.

OPENCODE_GO_API_KEY=
LITELLM_MASTER_KEY=
LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000
