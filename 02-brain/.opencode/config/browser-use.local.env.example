# Browser Use local MCP example environment.
# Do not commit real secrets. Copy this to browser-use.local.env.
#
# Preferred local route for this workspace:
# Browser Use -> LiteLLM proxy -> OpenCode Go glm-5.
#
# OPENAI_API_KEY must be the LiteLLM proxy master key, not the OpenCode Go key.
# Keep the OpenCode Go key in litellm-opencode-go.local.env as OPENCODE_GO_API_KEY.

OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:4000/v1
OPENAI_API_BASE=http://127.0.0.1:4000/v1
ANTHROPIC_API_KEY=
BROWSER_USE_HEADLESS=false
