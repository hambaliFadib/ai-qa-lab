# Telegram bug reporting config.
# Copy this file to telegram-bug-reporter.local.env and fill local secrets there.

TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# Optional for Telegram group topics/supergroup forum threads.
# TELEGRAM_THREAD_ID=123

# Optional defaults used in messages.
TELEGRAM_REPORT_PREFIX=[PGN Billing QA]
TELEGRAM_PARSE_MODE=HTML
